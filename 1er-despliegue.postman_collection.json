{
  "info": {
    "_postman_id": "5fd32b2f-f087-4600-9a74-07ed28e23cd2",
    "name": "1er Despliegue API Railway",
    "description": "Coleccion para probar la API desplegada en Railway.",
    "schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json"
  },
  "variable": [
    {
      "key": "baseUrl",
      "value": "https://1er-despliegue-production.up.railway.app"
    },
    {
      "key": "taskId",
      "value": "1"
    }
  ],
  "item": [
    {
      "name": "Health Root",
      "request": {
        "method": "GET",
        "url": "{{baseUrl}}/"
      }
    },
    {
      "name": "Get All Tasks",
      "request": {
        "method": "GET",
        "url": "{{baseUrl}}/api/tasks"
      }
    },
    {
      "name": "Get Task By Id",
      "request": {
        "method": "GET",
        "url": "{{baseUrl}}/api/tasks/{{taskId}}"
      }
    },
    {
      "name": "Create Task",
      "event": [
        {
          "listen": "test",
          "script": {
            "type": "text/javascript",
            "exec": [
              "pm.test('Status 201', function () {",
              "  pm.response.to.have.status(201);",
              "});",
              "var body = pm.response.json();",
              "if (body && body.id) pm.collectionVariables.set('taskId', String(body.id));"
            ]
          }
        }
      ],
      "request": {
        "method": "POST",
        "header": [
          {
            "key": "Content-Type",
            "value": "application/json"
          }
        ],
        "body": {
          "mode": "raw",
          "raw": "{\n  \"title\": \"Prueba desde Postman\",\n  \"completed\": false\n}"
        },
        "url": "{{baseUrl}}/api/tasks"
      }
    },
    {
      "name": "Update Task",
      "request": {
        "method": "PUT",
        "header": [
          {
            "key": "Content-Type",
            "value": "application/json"
          }
        ],
        "body": {
          "mode": "raw",
          "raw": "{\n  \"title\": \"Actualizada desde Postman\",\n  \"completed\": true\n}"
        },
        "url": "{{baseUrl}}/api/tasks/{{taskId}}"
      }
    },
    {
      "name": "Delete Task",
      "request": {
        "method": "DELETE",
        "url": "{{baseUrl}}/api/tasks/{{taskId}}"
      }
    }
  ]
}
